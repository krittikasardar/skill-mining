# GitHub Personal Access Token (classic or fine-grained, public repo read scope is sufficient)
GITHUB_TOKEN=your_github_token_here

# Optional: comma-separated list of usernames to process as a default
# GITHUB_USERNAMES=torvalds,gvanrossum,antirez

# Optional: output directory override (default: ./data)
# OUTPUT_DIR=./data

# Optional: enable disk cache to avoid re-fetching (true/false)
# ENABLE_CACHE=true
